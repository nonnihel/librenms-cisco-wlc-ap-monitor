  "type": "library",
  "license": "GPL-3.0-or-later",
  "require": {
    "php": ">=8.2",
    "illuminate/support": "*",
    "illuminate/database": "*",
    "illuminate/routing": "*",
    "symfony/process": "*"
  },
  "autoload": {
    "psr-4": {
      "Averna\\CiscoWlcApMonitor\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Averna\\CiscoWlcApMonitor\\CiscoWlcApMonitorServiceProvider"
      ]
    }
  }
}
